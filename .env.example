# Local test mode is explicit and never used in production.
# Set to 1 only for local deterministic E2E runs without Supabase credentials.
EVALOPS_TEST_MODE=0
EVALOPS_TEST_STORE_PATH=.evalops

# Supabase Auth, Postgres + Storage
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Legacy name accepted by the server adapter if SUPABASE_SECRET_KEY is unset:
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI Responses API structured audit generation.
OPENAI_API_KEY=
OPENAI_AUDIT_MODEL=gpt-5.5

# Optional production observability/deployment integrations
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Token-protected readiness and live production smoke checks.
EVALOPS_SMOKE_TOKEN=
EVALOPS_BASE_URL=https://evalops-copilot.vercel.app
EVALOPS_SMOKE_EMAIL=
EVALOPS_SMOKE_PASSWORD=
EVALOPS_SMOKE_SECONDARY_EMAIL=
EVALOPS_SMOKE_SECONDARY_PASSWORD=
EVALOPS_SMOKE_TIMEOUT_MS=180000
EVALOPS_SMOKE_POLL_INTERVAL_MS=5000

VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
