# Local test mode is explicit and never used in production.
# Set to 1 only for local deterministic E2E runs without Supabase credentials.
EVALOPS_TEST_MODE=0
EVALOPS_TEST_STORE_PATH=.evalops

# Supabase Auth, Postgres + Storage
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Legacy name accepted by the server adapter if SUPABASE_SECRET_KEY is unset:
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI Responses API, used by future structured generation adapters.
OPENAI_API_KEY=

# Optional production observability/deployment integrations
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
