# EvalOps Copilot environment template
# Copy to .env.local for local development. Never commit real values.

# Local deterministic mode.
# Required for local/E2E runs without live Supabase, OpenAI, or Inngest credentials.
# Must be unset or 0 in hosted preview/production.
EVALOPS_TEST_MODE=0
EVALOPS_TEST_STORE_PATH=.evalops

# Public app URL.
# Optional locally; used to build Supabase email confirmation redirects.
# Required in production if request origin cannot be trusted/inferred.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Auth, Postgres, and Storage.
# Required outside EVALOPS_TEST_MODE=1.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only Supabase service credential.
# Required outside EVALOPS_TEST_MODE=1. Prefer SUPABASE_SECRET_KEY.
SUPABASE_SECRET_KEY=

# Legacy alias accepted by the server adapter if SUPABASE_SECRET_KEY is unset.
# Server-only; never expose as NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI Responses API.
# Required for production audit generation and Evaller AI test runs.
OPENAI_API_KEY=
OPENAI_AUDIT_MODEL=gpt-5.5
OPENAI_EVALLER_MODEL=gpt-5.5

# Inngest async processing.
# Required for production trace import, export, and deletion workflows.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Stripe billing.
# Required for billing checkout/portal/webhook paths and readiness checks.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=

# Optional observability and analytics.
# Configure only after privacy copy and capture policy are approved.
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Token-protected readiness and live production smoke checks.
# Required only for npm run smoke:production and /api/readiness.
EVALOPS_SMOKE_TOKEN=
EVALOPS_BASE_URL=https://evalops-copilot.vercel.app
EVALOPS_SMOKE_EMAIL=
EVALOPS_SMOKE_PASSWORD=
EVALOPS_SMOKE_SECONDARY_EMAIL=
EVALOPS_SMOKE_SECONDARY_PASSWORD=
EVALOPS_SMOKE_TIMEOUT_MS=180000
EVALOPS_SMOKE_POLL_INTERVAL_MS=5000

# Vercel deployment automation.
# Optional; do not commit real values.
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Google Sheet command centre sync.
# Optional. If COMMAND_CENTRE_WEBHOOK_URL is set, the export script can POST roadmap rows.
# If using direct Sheets API in a future script, keep credentials outside the repo.
COMMAND_CENTRE_WEBHOOK_URL=
GOOGLE_SHEET_ID=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Optional Supabase local/provider secrets referenced by supabase/config.toml templates.
# Not required for the current local app unless those providers are enabled.
SUPABASE_AUTH_SMS_TWILIO_AUTH_TOKEN=
SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=
